{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "0.1.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "corvus@corvus-mail.dev",
      "strict_min_version": "128.0"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "permissions": [
    "messagesRead",
    "messagesMove",
    "messagesDelete",
    "messagesTags",
    "accountsRead",
    "accountsFolders",
    "compose",
    "compose.send",
    "storage",
    "notifications",
    "alarms",
    "menus"
  ],
  "action": {
    "default_title": "Corvus AI",
    "default_popup": "ui/index.html?page=chat",
    "default_icon": {
      "16": "icons/corvus-16.png",
      "32": "icons/corvus-32.png"
    }
  },
  "message_display_action": {
    "default_title": "Corvus AI",
    "default_popup": "ui/index.html?page=msgDisplay"
  },
  "compose_action": {
    "default_title": "Corvus AI Assist",
    "default_popup": "ui/index.html?page=compose"
  },
  "icons": {
    "48": "icons/corvus-48.png",
    "128": "icons/corvus-128.png"
  }
}
