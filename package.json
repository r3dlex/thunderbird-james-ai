{
  "name": "corvus",
  "version": "0.1.0",
  "description": "AI-powered Thunderbird extension with multi-provider support",
  "private": true,
  "scripts": {
    "dev": "concurrently \"webpack --watch --mode=development\" \"cd src/ui && npx ng build --watch --configuration=development\"",
    "build": "webpack --mode=production && cd src/ui && npx ng build --configuration=production && cd ../.. && node scripts/merge-dist.mjs",
    "build:background": "webpack --mode=production",
    "build:ui": "cd src/ui && npx ng build --configuration=production",
    "package": "npm run build && cd dist && zip -r ../corvus.xpi * -x '*.map'",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ui": "cd src/ui && npx ng test --watch=false --code-coverage"
  },
  "devDependencies": {
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "^29.5.0",
    "@types/webextension-polyfill": "^0.12.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "dompurify": "^3.2.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "marked": "^15.0.0",
    "rxjs": "^7.8.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0",
    "zone.js": "^0.15.0"
  }
}
